[DDL] df_customer_profile
CREATE OR REPLACE TABLE df_customer_profile (
  customer_id INTEGER NOT NULL,
  platform_id VARCHAR NOT NULL,
  buyer_name VARCHAR,
  email VARCHAR,
  display_name VARCHAR GENERATED ALWAYS AS (buyer_name || ' (' || coalesce(email,'') || ')') VIRTUAL,
  derivation_timestamp TIMESTAMP,
  derivation_batch_id VARCHAR,
  derivation_script VARCHAR,
  PRIMARY KEY (platform_id, customer_id)
);

CREATE INDEX IF NOT EXISTS idx_df_customer_profile_platform_id_df_customer_profile ON df_customer_profile(platform_id); 
[DDL] df_customer_dna
CREATE OR REPLACE TABLE df_customer_dna (
  customer_id INTEGER NOT NULL,
  platform_id VARCHAR NOT NULL,
  product_line_id_filter VARCHAR,
  ipt DOUBLE,
  total_spent DOUBLE,
  times DOUBLE,
  zipcode DOUBLE,
  state DOUBLE,
  lat DOUBLE,
  lng DOUBLE,
  ipt_mean DOUBLE,
  m_value DOUBLE,
  ni DOUBLE,
  sigma_hnorm_mle DOUBLE,
  sigma_hnorm_bcmle DOUBLE,
  m_ecdf DOUBLE,
  m_label VARCHAR,
  date TIMESTAMP,
  sum_spent_by_date DOUBLE,
  count_transactions_by_date DOUBLE,
  min_time_by_date TIMESTAMP,
  payment_time TIMESTAMP,
  ni_ipt DOUBLE,
  difftime DOUBLE,
  nes_ratio DOUBLE,
  nes_status VARCHAR,
  f_value DOUBLE,
  f_ecdf DOUBLE,
  f_label VARCHAR,
  r_value DOUBLE,
  r_ecdf DOUBLE,
  r_label VARCHAR,
  mle DOUBLE,
  wmle DOUBLE,
  cai_value DOUBLE,
  cai_ecdf DOUBLE,
  cai_label VARCHAR,
  pcv DOUBLE,
  total_sum DOUBLE,
  clv DOUBLE,
  time_first TIMESTAMP,
  nt DOUBLE,
  time_first_to_now DOUBLE,
  e0t DOUBLE,
  ge DOUBLE,
  ie DOUBLE,
  be DOUBLE,
  cri DOUBLE,
  cri_ecdf DOUBLE,
  be2 DOUBLE,
  nrec_prob DOUBLE,
  nrec VARCHAR,
  nes_value DOUBLE,
  cai DOUBLE,
  dna_m_score DOUBLE,
  dna_f_score DOUBLE,
  dna_r_score DOUBLE,
  dna_segment VARCHAR,
  derivation_timestamp TIMESTAMP,
  derivation_batch_id VARCHAR,
  derivation_script VARCHAR,
  PRIMARY KEY (platform_id, customer_id, product_line_id_filter)
);

CREATE INDEX IF NOT EXISTS idx_df_customer_dna_platform_id_df_customer_dna ON df_customer_dna(platform_id);

CREATE INDEX IF NOT EXISTS idx_df_customer_dna_platform_id_product_line_id_filter_df_customer_dna ON df_customer_dna(platform_id, product_line_id_filter); 
[DDL] df_customer_segments
CREATE OR REPLACE TABLE df_customer_segments (
  customer_id INTEGER NOT NULL,
  platform_id VARCHAR NOT NULL,
  product_line_id_filter VARCHAR,
  nes_status VARCHAR,
  dna_segment VARCHAR,
  cai DOUBLE,
  value_tier VARCHAR,
  derivation_timestamp TIMESTAMP,
  derivation_batch_id VARCHAR,
  derivation_script VARCHAR,
  PRIMARY KEY (platform_id, customer_id, product_line_id_filter)
);

CREATE INDEX IF NOT EXISTS idx_df_customer_segments_platform_id_df_customer_segments ON df_customer_segments(platform_id);

CREATE INDEX IF NOT EXISTS idx_df_customer_segments_platform_id_product_line_id_filter_df_customer_segments ON df_customer_segments(platform_id, product_line_id_filter); 
